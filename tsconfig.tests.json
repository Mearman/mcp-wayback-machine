{
	"compilerOptions": {
		"target": "ES2024",
		"module": "Node16",
		"moduleResolution": "Node16",
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"exactOptionalPropertyTypes": true,
		"noImplicitReturns": true,
		"noFallthroughCasesInSwitch": true,
		"skipLibCheck": true,
		"types": ["node"],
		"noEmit": true
	},
	"include": ["src", "tests"]
}
